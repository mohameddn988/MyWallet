# Full URL of the backend API server
# Dev: use your machine's LAN IP so physical devices connect (e.g. http://192.168.1.x:4000)
# Prod: your deployed backend URL (e.g. https://mywallet-x45i.onrender.com)
EXPO_PUBLIC_API_URL=https://mywallet-x45i.onrender.com

# Backend port used in dev when EXPO_PUBLIC_API_URL is not set
EXPO_PUBLIC_API_PORT=4000

# Google OAuth client IDs — get these from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
